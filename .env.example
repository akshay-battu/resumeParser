DATABASE_URL=sqlite:///traqcheck.db
UPLOAD_FOLDER=uploads
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
FLASK_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
MAX_UPLOAD_MB=10

# SMTP — outbound email (e.g. Gmail: smtp.gmail.com, port 587, an App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=ResumeParser Recruiting
SMTP_USE_TLS=true

# IMAP — inbound email auto-ingest (Gmail/Outlook credentials)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
